# Copy to .env and adjust as needed: docker compose reads .env automatically.

# Ports exposed on the host (change if already taken by another app)
DB_PORT=5432
# Single port serving both the frontend (/) and the API (/api/*) — the api
# container itself is never published on the host, only web (nginx) is.
APP_PORT=8081

# Postgres credentials (used by the db, migrate and api services)
POSTGRES_USER=opencharge
POSTGRES_PASSWORD=opencharge
POSTGRES_DB=opencharge

# API (only matters if the api container is queried directly, bypassing
# the web container's reverse proxy — e.g. local non-Docker dev)
CORS_ORIGIN=*

# Frontend build arg: base path/URL the browser uses to reach the API.
# Baked in at build time (Vite env vars are compile-time). Defaults to
# "/api", relative to the page's own origin (served by the web container's
# nginx, which reverse-proxies /api/* to the api container). Only set this
# to an absolute URL (e.g. http://localhost:8080) if running the frontend
# dev server (npm run dev) against a standalone API, outside Docker.
VITE_API_BASE_URL=/api
