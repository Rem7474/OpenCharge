# Copy to .env and adjust as needed: docker compose reads .env automatically.

# Ports exposed on the host (change if already taken by another app)
DB_PORT=5432
API_PORT=8080
WEB_PORT=5173

# Postgres credentials (used by the db, migrate and api services)
POSTGRES_USER=opencharge
POSTGRES_PASSWORD=opencharge
POSTGRES_DB=opencharge

# API
CORS_ORIGIN=*

# Frontend build arg: public URL the browser uses to reach the API.
# Baked in at build time (Vite env vars are compile-time) — update this and
# rebuild the web image if you change API_PORT.
VITE_API_BASE_URL=http://localhost:8080
