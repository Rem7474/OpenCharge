# Copy to keystore.properties (gitignored) for a local signed release build,
# or set the equivalent ANDROID_KEYSTORE_BASE64/ANDROID_KEYSTORE_PASSWORD/
# ANDROID_KEY_ALIAS/ANDROID_KEY_PASSWORD secrets for CI (see
# .github/workflows/mobile-android.yml). storeFile is resolved relative to
# this android/ directory.
storeFile=release.keystore
storePassword=
keyAlias=
keyPassword=
